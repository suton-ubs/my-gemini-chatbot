# Environment variables for development
NODE_ENV=development

# Server port
PORT=3000

# CORS origins allowed to access the API, comma-separated
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:3001

# Gemini Keys
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash-lite
GEMINI_ALLOWED_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# Gemini Behavior
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_K=40
GEMINI_TOP_P=0.9
GEMINI_MAX_TOKENS=8192
SYSTEM_INSTRUCTION=You are a helpful assistant that provides accurate and concise information. Always answer in a clear and informative manner, and ask for clarification if the user's request is ambiguous.

# Limit file upload types for security
ALLOWED_UPLOAD_EXTENSIONS=pdf,txt,mp3,wav,png,bmp,jpg,jpeg,webp
MAX_UPLOAD_SIZE_MB=20

# Access code for protected endpoints (leave empty to disable)
ACCESS_CODE=